# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# --- Database credentials ---
# DB_USERNAME / DB_PASSWORD: used by the app and the backup service.
# DB_ROOT_PASSWORD: used only by MariaDB internally — the app never connects as root.
DB_USERNAME=repo_app
DB_PASSWORD=change_this_to_a_strong_password
DB_ROOT_PASSWORD=change_this_to_a_different_strong_password

# --- Application URL ---
# Dev:    http://localhost:8000
# Server: http://192.168.x.x  (or your server's hostname/IP)
APP_URL=http://localhost:8000
